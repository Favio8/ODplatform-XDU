# ============================================================
# ODPlatform 专属(Stage 1 Monorepo 路径)
# ============================================================

# 数据集不进 git(走外部存储或 Git LFS)
data/raw/*
!data/raw/.gitkeep
data/_backup_splits/
data/processed/*
!data/processed/.gitkeep
data/yolo/*
!data/yolo/.gitkeep
data/train/
data/val/
data/test/
!data/README.md
!data/.gitkeep

# 模型权重不进 git
models/pretrained/*.pt
models/checkpoints/*.pt
models/checkpoints/*/
models/serving/*.pt
!models/pretrained/README.md
!models/checkpoints/README.md
!models/serving/README.md

# 训练运行结果(每次自动产生新目录)
runs/*
!runs/README.md

# 端私有日志(运行时产生,各机器不同)
node_modules/
.vite/
# 根目录不承载 Node 工程；前端依赖锁定在 apps/web-frontend/
/package.json
/package-lock.json
apps/web-frontend/node_modules/
apps/web-frontend/dist/
apps/web-frontend/*.tsbuildinfo
apps/web-frontend/vite.config.d.ts
apps/web-frontend/vite.config.js
apps/platform/logging/
apps/platform/configs/train.d5-demo.yaml
apps/platform/configs/datasets/test_cn.yaml
apps/platform/src/odp_platform/data_pipeline-mentor/
【学生成果物】*/
docs/architecture/ADR-001-monorepo.md

